PORT=5001
MONGODB_URI=mongodb://localhost:27018/acharitiwari
JWT_SECRET=your_jwt_secret_key_change_this_in_production
NEWSLETTER_SECRET=use_a_separate_long_random_secret_in_production
JWT_EXPIRE=7d
NODE_ENV=development
ADMIN_EMAIL=admin@acharitiwari.com
ADMIN_PASSWORD=replace_with_a_strong_initial_password
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080

# Cloudinary server-side media storage. Never expose this value in frontend code.
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_provider_app_password
EMAIL_FROM=Achari Tiwari <orders@yourdomain.com>
SUPPORT_EMAIL=aacharitiwari@gmail.com
SITE_URL=https://www.aacharitiwari.com
PUBLIC_API_URL=https://api.yourdomain.com/api

# AI blog automation. Keep these server-side and use the same CRON_SECRET in GitHub Actions.
GEMINI_API_KEY=your-rotated-server-side-gemini-key
GEMINI_TEXT_MODEL=gemini-3.6-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image
CRON_SECRET=replace-with-a-long-random-secret
