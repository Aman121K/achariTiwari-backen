PORT=5001
MONGODB_URI=mongodb://localhost:27018/acharitiwari
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRE=7d
NODE_ENV=development
ADMIN_EMAIL=admin@acharitiwari.com
ADMIN_PASSWORD=replace_with_a_strong_initial_password
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080

# AWS S3 media storage. Use an IAM role in production when possible.
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-private-media-bucket
# Public CloudFront distribution URL recommended for storefront delivery.
AWS_CLOUDFRONT_URL=https://media.yourdomain.com
# For local development only; production should use an IAM role/task role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=Achari Tiwari <orders@yourdomain.com>
SUPPORT_EMAIL=aacharitiwari@gmail.com
SITE_URL=https://www.aacharitiwari.com
